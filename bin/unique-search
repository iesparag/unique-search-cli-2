#!/usr/bin/env node
import { readInput } from '../src/input/readInput.js';
import { filterUnique } from '../src/processing/filterUnique.js';
import { matchItems } from '../src/search/matchItems.js';
import { outputResults } from '../src/output/outputResults.js';

const VERSION = '0.1.0';
const USAGE = `
unique-search - A unique-line search tool

Usage:
  unique-search [options] <search_query> [input_file]

Options:
  --help                Show this help message and exit
  --version             Show version info and exit
  --ignore-case         Make search case-insensitive (default)
  --case-sensitive      Make search case-sensitive
  --regex               Search using a regular expression (with error handling)
  --unique-by <field>   Assume JSON lines; filter unique by field and match by field value
`;

function printUsage() {
  process.stdout.write(USAGE);
}

function printVersion() {
  process.stdout.write(`${VERSION}\n`);
}

// CLI parsing for options
default: (no --case-sensitive nor --ignore-case): case-insensitive
// Accepts: unique-search [options] <search_query> [input_file]
const args = process.argv.slice(2);
if (args.includes('--help')) {
  printUsage();
  process.exit(0);
} else if (args.includes('--version')) {
  printVersion();
  process.exit(0);
}

// Whether to use regex
const useRegex = args.includes('--regex');
// explicit case flags (cannot both be set at once; last takes precedence)
const ignoreCaseIx = args.lastIndexOf('--ignore-case');
const caseSensitiveIx = args.lastIndexOf('--case-sensitive');
let caseSensitive;
if (caseSensitiveIx !== -1 && ignoreCaseIx !== -1) {
  // If both are present: which comes last wins
  caseSensitive = caseSensitiveIx > ignoreCaseIx;
} else if (caseSensitiveIx !== -1) {
  caseSensitive = true;
} else if (ignoreCaseIx !== -1) {
  caseSensitive = false;
} else {
  caseSensitive = false; // default is case-insensitive
}

// Parse --unique-by <field> option
let uniqueByField = undefined;
const uniqueByIdx = args.indexOf('--unique-by');
if (uniqueByIdx !== -1) {
  if (!args[uniqueByIdx + 1] || args[uniqueByIdx + 1].startsWith('--')) {
    process.stderr.write('Error: --unique-by must be followed by a field name.\n');
    printUsage();
    process.exit(1);
  }
  uniqueByField = args[uniqueByIdx + 1];
}

// Remove options from args for positional args
let i = 0;
const nonOptArgs = [];
while (i < args.length) {
  const a = args[i];
  if (a === '--unique-by') { i += 2; continue; }
  if (a === '--regex' || a === '--ignore-case' || a === '--case-sensitive' || a === '--help' || a === '--version') {
    i++;
    continue;
  }
  if (!a.startsWith('--')) nonOptArgs.push(a);
  i++;
}
const searchQuery = nonOptArgs[0];
const inputFileArg = nonOptArgs[1];

if (!searchQuery) {
  process.stderr.write('Error: Missing <search_query>.\n');
  printUsage();
  process.exit(1);
}

(async () => {
  try {
    const lines = await readInput(inputFileArg, { jsonLines: Boolean(uniqueByField) });
    if (!lines || lines.length === 0) {
      outputResults("__NO_INPUT__");
      return;
    }
    // Deduplicate before search
    const uniqueItems = filterUnique(lines, uniqueByField);
    let matched;
    try {
      matched = matchItems(uniqueItems, searchQuery, {
        caseSensitive,
        regex: useRegex,
        uniqueByField,
      });
    } catch (err) {
      if (useRegex && /Invalid regular expression pattern/.test(err.message)) {
        process.stderr.write(`Regex error: ${err.message}\n`);
        process.exit(2);
      } else {
        throw err;
      }
    }
    outputResults(matched, { json: Boolean(uniqueByField) });
  } catch (err) {
    process.stderr.write(`Error: ${err.message}\n`);
    process.exit(1);
  }
})();

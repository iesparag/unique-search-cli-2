#!/usr/bin/env node
import { readInput } from '../src/input/readInput.js';

const VERSION = '0.1.0';
const USAGE = `
unique-search - A unique-line search tool

Usage:
  unique-search [options] <search_query> [input_file]

Options:
  --help        Show this help message and exit
  --version     Show version info and exit
`;

function printUsage() {
  process.stdout.write(USAGE);
}

function printVersion() {
  process.stdout.write(`${VERSION}\n`);
}

// Minimal CLI parsing for --help and --version
const args = process.argv.slice(2);
if (args.includes('--help')) {
  printUsage();
  process.exit(0);
} else if (args.includes('--version')) {
  printVersion();
  process.exit(0);
}

// Accept: unique-search [options] <search_query> [input_file]
if (!args.length) {
  printUsage();
  process.exit(1);
}

// Parse arguments: find first non-option arg as search_query, then [input_file]
const nonOptArgs = args.filter(arg => !arg.startsWith('--'));
const searchQuery = nonOptArgs[0];
const inputFileArg = nonOptArgs[1];

if (!searchQuery) {
  process.stderr.write('Error: Missing <search_query>.\n');
  printUsage();
  process.exit(1);
}

(async () => {
  try {
    const lines = await readInput(inputFileArg);
    // Proof of concept: just print number of lines read
    process.stdout.write(`Read ${lines.length} lines.\n`);
    // For later: pass to uniqueness+search modules
  } catch (err) {
    process.stderr.write(`Error: ${err.message}\n`);
    process.exit(1);
  }
})();
